//! Production-Ready Inference Server
//!
//! This server provides a robust HTTP/WebSocket API for model inference,
//! integrating all UniLLM optimizations including GPU acceleration, quantization,
//! distributed inference, and advanced memory management.

use axum::{
    extract::{Path, Query, State, WebSocketUpgrade},
    http::StatusCode,
    response::{Json, Response, Sse, IntoResponse},
    routing::{get, post},
    Router,
};
use axum::response::sse::{Event, KeepAlive};
use futures_util::stream::{Stream, StreamExt};
use axum_extra::headers::{authorization::Bearer, Authorization};
use axum_extra::TypedHeader;
use serde::{Deserialize, Serialize};
use std::collections::HashMap;
use std::sync::Arc;
use std::time::{Duration, Instant};
use tokio::sync::{mpsc, RwLock};
use tower::ServiceBuilder;
use tower_http::cors::CorsLayer;
use tower_http::services::ServeDir;
use uuid::Uuid;

use runtime::{
    distributed::{DistributedInferenceEngine, ParallelismStrategy},
    gpu_tensor_ops::GpuDevice,
    quantization::{QuantizationConfig, QuantizationType, MixedPrecisionPolicy},
    request_batching::{ContinuousBatcher, BatchingConfig, GenerationRequest},
    memory_pool::{AdvancedMemoryPool, MemoryPoolConfig},
    kv_cache::KVCache,
    inference::{InferenceEngine, InferenceRequest, InferenceResult},
    streaming_inference::{StreamingInferenceEngine, StreamingRequest, StreamOptions, SSEFormatter},
};

/// Server configuration
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ServerConfig {
    pub host: String,
    pub port: u16,
    pub max_concurrent_requests: usize,
    pub max_batch_size: usize,
    pub max_sequence_length: usize,
    pub request_timeout_ms: u64,
    pub enable_gpu: bool,
    pub enable_quantization: bool,
    pub quantization_type: QuantizationType,
    pub enable_distributed: bool,
    pub num_gpu_workers: usize,
    pub mixed_precision_policy: Option<MixedPrecisionPolicy>,
    pub memory_pool_size_mb: usize,
}

impl Default for ServerConfig {
    fn default() -> Self {
        Self {
            host: "0.0.0.0".to_string(),
            port: 8080,
            max_concurrent_requests: 100,
            max_batch_size: 32,
            max_sequence_length: 2048,
            request_timeout_ms: 30000,
            enable_gpu: true,
            enable_quantization: true,
            quantization_type: QuantizationType::FP16,
            enable_distributed: false,
            num_gpu_workers: 1,
            mixed_precision_policy: Some(MixedPrecisionPolicy::AttentionFP16),
            memory_pool_size_mb: 4096,
        }
    }
}

/// Request models
#[derive(Debug, Serialize, Deserialize)]
pub struct ChatCompletionRequest {
    pub model: String,
    pub messages: Vec<ChatMessage>,
    pub temperature: Option<f32>,
    pub max_tokens: Option<usize>,
    pub stream: Option<bool>,
    pub top_p: Option<f32>,
    pub frequency_penalty: Option<f32>,
    pub presence_penalty: Option<f32>,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct ChatMessage {
    pub role: String,
    pub content: String,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct CompletionRequest {
    pub model: String,
    pub prompt: String,
    pub temperature: Option<f32>,
    pub max_tokens: Option<usize>,
    pub stream: Option<bool>,
    pub top_p: Option<f32>,
}

/// Response models
#[derive(Debug, Serialize, Deserialize)]
pub struct ChatCompletionResponse {
    pub id: String,
    pub object: String,
    pub created: u64,
    pub model: String,
    pub choices: Vec<ChatChoice>,
    pub usage: Usage,
    pub system_fingerprint: String,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct ChatChoice {
    pub index: usize,
    pub message: ChatMessage,
    pub finish_reason: String,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct CompletionResponse {
    pub id: String,
    pub object: String,
    pub created: u64,
    pub model: String,
    pub choices: Vec<CompletionChoice>,
    pub usage: Usage,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct CompletionChoice {
    pub text: String,
    pub index: usize,
    pub finish_reason: String,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct Usage {
    pub prompt_tokens: usize,
    pub completion_tokens: usize,
    pub total_tokens: usize,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct ServerStatus {
    pub status: String,
    pub version: String,
    pub uptime_seconds: u64,
    pub active_requests: usize,
    pub total_requests: u64,
    pub gpu_enabled: bool,
    pub distributed_enabled: bool,
    pub quantization_enabled: bool,
    pub memory_usage_mb: usize,
    pub cache_hit_rate: f32,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct ModelInfo {
    pub id: String,
    pub object: String,
    pub owned_by: String,
    pub permission: Vec<String>,
}

/// Server state
pub struct AppState {
    pub config: ServerConfig,
    pub inference_engine: Arc<InferenceEngine>,
    pub streaming_engine: Arc<StreamingInferenceEngine>,
    pub distributed_engine: Option<Arc<DistributedInferenceEngine>>,
    pub batcher: Arc<RwLock<ContinuousBatcher>>,
    pub memory_pool: Arc<AdvancedMemoryPool>,
    pub kv_cache: Arc<RwLock<KVCache>>,
    pub request_counter: Arc<RwLock<u64>>,
    pub active_requests: Arc<RwLock<HashMap<Uuid, Instant>>>,
    pub server_start_time: Instant,
}

impl AppState {
    pub async fn new(config: ServerConfig) -> Result<Self, Box<dyn std::error::Error>> {
        // Initialize GPU device
        let device = if config.enable_gpu {
            GpuDevice::auto_detect()
        } else {
            GpuDevice::Cpu
        };

        // Initialize memory pool
        let pool_config = MemoryPoolConfig {
            initial_size_mb: config.memory_pool_size_mb,
            max_size_mb: config.memory_pool_size_mb * 4,
            allocation_alignment: 256,
            enable_defragmentation: true,
            gc_threshold: 0.8,
        };
        let memory_pool = Arc::new(AdvancedMemoryPool::new(pool_config));

        // Initialize quantization config
        let quantization_config = if config.enable_quantization {
            let mut qconfig = QuantizationConfig::default();
            qconfig.weight_quantization = config.quantization_type;
            if let Some(policy) = config.mixed_precision_policy {
                qconfig.mixed_precision_policy = Some(policy);
            }
            Some(qconfig)
        } else {
            None
        };

        // Initialize inference engines
        let inference_engine = Arc::new(InferenceEngine::new(
            device.clone(),
            quantization_config,
        ));
        let streaming_engine = Arc::new(StreamingInferenceEngine::new(device.clone()));

        // Initialize distributed engine if enabled
        let distributed_engine = if config.enable_distributed && config.num_gpu_workers > 1 {
            let strategy = if config.num_gpu_workers <= 4 {
                ParallelismStrategy::DataParallel {
                    replicas: config.num_gpu_workers,
                }
            } else {
                ParallelismStrategy::Hybrid {
                    tensor_parallel_size: 2,
                    pipeline_stages: 2,
                    data_parallel_replicas: config.num_gpu_workers / 4,
                }
            };

            let engine = DistributedInferenceEngine::new(strategy, device.clone()).await?;
            Some(Arc::new(engine))
        } else {
            None
        };

        // Initialize continuous batcher
        let batching_config = BatchingConfig {
            max_batch_size: config.max_batch_size,
            max_sequence_length: config.max_sequence_length,
            timeout_ms: 100,
            dynamic_batching: true,
            priority_scheduling: true,
        };
        let batcher = Arc::new(RwLock::new(ContinuousBatcher::new(
            batching_config,
            device.clone(),
        )));

        // Initialize KV cache
        let kv_cache = Arc::new(RwLock::new(KVCache::new(
            config.max_batch_size,
            8, // num_heads
            64, // head_dim
            config.max_sequence_length,
            device,
        )));

        Ok(Self {
            config,
            inference_engine,
            streaming_engine,
            distributed_engine,
            batcher,
            memory_pool,
            kv_cache,
            request_counter: Arc::new(RwLock::new(0)),
            active_requests: Arc::new(RwLock::new(HashMap::new())),
            server_start_time: Instant::now(),
        })
    }

    pub async fn get_status(&self) -> ServerStatus {
        let request_counter = *self.request_counter.read().await;
        let active_requests = self.active_requests.read().await.len();
        let uptime = self.server_start_time.elapsed().as_secs();
        let memory_usage = self.memory_pool.total_allocated() / (1024 * 1024);
        let cache_stats = self.kv_cache.read().await.get_stats();

        ServerStatus {
            status: "healthy".to_string(),
            version: "1.0.0".to_string(),
            uptime_seconds: uptime,
            active_requests,
            total_requests: request_counter,
            gpu_enabled: self.config.enable_gpu,
            distributed_enabled: self.config.enable_distributed,
            quantization_enabled: self.config.enable_quantization,
            memory_usage_mb: memory_usage,
            cache_hit_rate: cache_stats.hit_ratio,
        }
    }
}

/// API Handlers

async fn health_check() -> &'static str {
    "OK"
}

async fn get_models() -> Json<Vec<ModelInfo>> {
    let models = vec![
        ModelInfo {
            id: "unillm-7b".to_string(),
            object: "model".to_string(),
            owned_by: "unillm".to_string(),
            permission: vec!["read".to_string()],
        },
        ModelInfo {
            id: "unillm-13b".to_string(),
            object: "model".to_string(),
            owned_by: "unillm".to_string(),
            permission: vec!["read".to_string()],
        },
    ];
    Json(models)
}

async fn get_status(State(state): State<Arc<AppState>>) -> Json<ServerStatus> {
    Json(state.get_status().await)
}

async fn chat_completions(
    State(state): State<Arc<AppState>>,
    _auth: Option<TypedHeader<Authorization<Bearer>>>,
    Json(request): Json<ChatCompletionRequest>,
) -> Result<Response, StatusCode> {
    // Check if streaming is requested
    if request.stream.unwrap_or(false) {
        return chat_completions_streaming(state, request).await;
    }

    // Non-streaming response (existing logic)
    let response = chat_completions_non_streaming(state, request).await?;
    Ok((StatusCode::OK, Json(response)).into_response())
}

async fn chat_completions_non_streaming(
    state: Arc<AppState>,
    request: ChatCompletionRequest,
) -> Result<ChatCompletionResponse, StatusCode> {
    let request_id = Uuid::new_v4();
    let start_time = Instant::now();

    // Track active request
    state.active_requests.write().await.insert(request_id, start_time);
    *state.request_counter.write().await += 1;

    // Convert messages to prompt
    let prompt = request
        .messages
        .iter()
        .map(|msg| format!("{}: {}", msg.role, msg.content))
        .collect::<Vec<_>>()
        .join("\n");

    // Create inference request
    let inference_request = InferenceRequest {
        prompt,
        max_tokens: request.max_tokens.unwrap_or(100),
        temperature: request.temperature.unwrap_or(0.7),
        top_p: request.top_p.unwrap_or(0.9),
        stop_sequences: vec![],
    };

    // Submit to batcher
    let generation_request = GenerationRequest::new(
        request_id.to_string(),
        inference_request.prompt.clone(),
        inference_request.max_tokens,
        inference_request.temperature,
        inference_request.top_p,
    );

    let mut batcher = state.batcher.write().await;
    batcher.add_request(generation_request).map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    // Process batch (simplified for demo)
    let _batch_results = batcher.process_next_batch().map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;
    drop(batcher);

    // Generate response using inference engine
    let result = state
        .inference_engine
        .generate(&inference_request)
        .await
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    // Clean up active request
    state.active_requests.write().await.remove(&request_id);

    let response = ChatCompletionResponse {
        id: format!("chatcmpl-{}", request_id),
        object: "chat.completion".to_string(),
        created: std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap()
            .as_secs(),
        model: request.model,
        choices: vec![ChatChoice {
            index: 0,
            message: ChatMessage {
                role: "assistant".to_string(),
                content: result.generated_text,
            },
            finish_reason: "stop".to_string(),
        }],
        usage: Usage {
            prompt_tokens: result.prompt_tokens,
            completion_tokens: result.completion_tokens,
            total_tokens: result.total_tokens,
        },
        system_fingerprint: "unillm-1.0".to_string(),
    };

    Ok(response)
}

async fn chat_completions_streaming(
    state: Arc<AppState>,
    request: ChatCompletionRequest,
) -> Result<Response, StatusCode> {
    let request_id = Uuid::new_v4();
    let start_time = Instant::now();

    // Track active request
    state.active_requests.write().await.insert(request_id, start_time);
    *state.request_counter.write().await += 1;

    // Convert messages to prompt
    let prompt = request
        .messages
        .iter()
        .map(|msg| format!("{}: {}", msg.role, msg.content))
        .collect::<Vec<_>>()
        .join("\n");

    // Create streaming request
    let streaming_request = StreamingRequest {
        request_id: request_id.to_string(),
        model_name: request.model.clone(),
        inference_request: InferenceRequest {
            prompt,
            max_tokens: request.max_tokens.unwrap_or(100),
            temperature: request.temperature.unwrap_or(0.7),
            top_p: request.top_p.unwrap_or(0.9),
            stop_sequences: vec![],
        },
        stream_options: StreamOptions::default(),
    };

    // Create SSE stream
    let stream = state.streaming_engine.generate_stream(streaming_request);
    let sse_stream = stream.map(|chunk_result| {
        match chunk_result {
            Ok(chunk) => {
                let json_data = serde_json::to_string(&chunk).unwrap();
                Ok(Event::default().data(json_data))
            }
            Err(e) => {
                let error_data = serde_json::json!({
                    "error": {
                        "message": e.to_string(),
                        "type": "server_error",
                        "code": "internal_error"
                    }
                });
                Ok(Event::default().data(error_data.to_string()))
            }
        }
    });

    // Clean up active request when stream completes
    let state_cleanup = state.clone();
    tokio::spawn(async move {
        tokio::time::sleep(tokio::time::Duration::from_secs(30)).await;
        state_cleanup.active_requests.write().await.remove(&request_id);
    });

    let sse = Sse::new(sse_stream)
        .keep_alive(KeepAlive::default());

    Ok(sse.into_response())
}

async fn completions(
    State(state): State<Arc<AppState>>,
    _auth: Option<TypedHeader<Authorization<Bearer>>>,
    Json(request): Json<CompletionRequest>,
) -> Result<Json<CompletionResponse>, StatusCode> {
    let request_id = Uuid::new_v4();
    let start_time = Instant::now();

    // Track active request
    state.active_requests.write().await.insert(request_id, start_time);
    *state.request_counter.write().await += 1;

    let inference_request = InferenceRequest {
        prompt: request.prompt,
        max_tokens: request.max_tokens.unwrap_or(100),
        temperature: request.temperature.unwrap_or(0.7),
        top_p: request.top_p.unwrap_or(0.9),
        stop_sequences: vec![],
    };

    let result = state
        .inference_engine
        .generate(&inference_request)
        .await
        .map_err(|_| StatusCode::INTERNAL_SERVER_ERROR)?;

    // Clean up active request
    state.active_requests.write().await.remove(&request_id);

    let response = CompletionResponse {
        id: format!("cmpl-{}", request_id),
        object: "text_completion".to_string(),
        created: std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap()
            .as_secs(),
        model: request.model,
        choices: vec![CompletionChoice {
            text: result.generated_text,
            index: 0,
            finish_reason: "stop".to_string(),
        }],
        usage: Usage {
            prompt_tokens: result.prompt_tokens,
            completion_tokens: result.completion_tokens,
            total_tokens: result.total_tokens,
        },
    };

    Ok(Json(response))
}

async fn websocket_handler(
    ws: WebSocketUpgrade,
    State(_state): State<Arc<AppState>>,
) -> Response {
    ws.on_upgrade(handle_websocket)
}

async fn handle_websocket(mut socket: axum::extract::ws::WebSocket) {
    use axum::extract::ws::Message;
    use futures::SinkExt;

    // WebSocket handling for streaming responses
    while let Some(msg) = socket.recv().await {
        match msg {
            Ok(Message::Text(text)) => {
                // Parse streaming request and respond
                let response = format!("Echo: {}", text);
                if socket.send(Message::Text(response)).await.is_err() {
                    break;
                }
            }
            Ok(Message::Close(_)) => break,
            _ => {}
        }
    }
}

fn create_app(state: Arc<AppState>) -> Router {
    Router::new()
        .route("/health", get(health_check))
        .route("/v1/models", get(get_models))
        .route("/v1/chat/completions", post(chat_completions))
        .route("/v1/completions", post(completions))
        .route("/status", get(get_status))
        .route("/ws", get(websocket_handler))
        .nest_service("/", ServeDir::new("public"))
        .layer(
            ServiceBuilder::new()
                .layer(CorsLayer::permissive())
                .into_inner(),
        )
        .with_state(state)
}

#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    println!("🚀 Starting UniLLM Inference Server");

    // Load configuration
    let config = ServerConfig::default();
    println!("📋 Server Configuration:");
    println!("   Host: {}:{}", config.host, config.port);
    println!("   GPU Enabled: {}", config.enable_gpu);
    println!("   Quantization: {} ({:?})", config.enable_quantization, config.quantization_type);
    println!("   Distributed: {} ({} workers)", config.enable_distributed, config.num_gpu_workers);
    println!("   Memory Pool: {} MB", config.memory_pool_size_mb);
    println!("   Max Batch Size: {}", config.max_batch_size);
    println!("   Max Sequence Length: {}", config.max_sequence_length);

    // Initialize server state
    println!("🔧 Initializing server components...");
    let state = Arc::new(AppState::new(config.clone()).await?);

    println!("✅ Server initialized successfully!");
    println!("🔧 Memory pool allocated: {} MB", state.memory_pool.total_allocated() / 1024 / 1024);

    // Create and start server
    let app = create_app(state);
    let bind_addr = format!("{}:{}", config.host, config.port);

    println!("🌐 Server listening on http://{}", bind_addr);
    println!("📚 API Documentation:");
    println!("   Health: GET /health");
    println!("   Models: GET /v1/models");
    println!("   Chat: POST /v1/chat/completions");
    println!("   Completions: POST /v1/completions");
    println!("   Status: GET /status");
    println!("   WebSocket: WS /ws");

    let listener = tokio::net::TcpListener::bind(&bind_addr).await?;
    axum::serve(listener, app).await?;

    Ok(())
}

#[cfg(test)]
mod tests {
    use super::*;
    use axum_test::TestServer;

    #[tokio::test]
    async fn test_health_endpoint() {
        let config = ServerConfig::default();
        let state = Arc::new(AppState::new(config).await.unwrap());
        let app = create_app(state);
        let server = TestServer::new(app).unwrap();

        let response = server.get("/health").await;
        assert_eq!(response.status_code(), 200);
        assert_eq!(response.text(), "OK");
    }

    #[tokio::test]
    async fn test_models_endpoint() {
        let config = ServerConfig::default();
        let state = Arc::new(AppState::new(config).await.unwrap());
        let app = create_app(state);
        let server = TestServer::new(app).unwrap();

        let response = server.get("/v1/models").await;
        assert_eq!(response.status_code(), 200);

        let models: Vec<ModelInfo> = response.json();
        assert!(!models.is_empty());
        assert_eq!(models[0].id, "unillm-7b");
    }

    #[tokio::test]
    async fn test_status_endpoint() {
        let config = ServerConfig::default();
        let state = Arc::new(AppState::new(config).await.unwrap());
        let app = create_app(state);
        let server = TestServer::new(app).unwrap();

        let response = server.get("/status").await;
        assert_eq!(response.status_code(), 200);

        let status: ServerStatus = response.json();
        assert_eq!(status.status, "healthy");
        assert_eq!(status.version, "1.0.0");
    }
}